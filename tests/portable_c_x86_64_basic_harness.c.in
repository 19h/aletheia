#define _main decompiled_main
#include "@GENERATED_C@"
#undef _main

static int verify_combine4(void) {
    static const unsigned long values[] = {
        0UL, 1UL, 2UL, 7UL, 31UL, 0xffffUL,
    };
    for (size_t i = 0; i < sizeof(values) / sizeof(values[0]); ++i) {
        for (size_t j = 0; j < sizeof(values) / sizeof(values[0]); ++j) {
            const unsigned long a0 = values[i];
            const unsigned long a1 = values[j];
            const unsigned long a2 = values[(i + j) % 6UL];
            const unsigned long a3 = values[(i * 3UL + j) % 6UL];
            const unsigned long expected =
                a0 + 3UL * a1 + 5UL * a2 + 7UL * a3;
            if (_combine4(a0, a1, a2, a3) != expected) return 10;
        }
    }
    return 0;
}

int main(void) {
    const int function_result = verify_combine4();
    if (function_result != 0) return function_result;
    return decompiled_main(0UL, 0UL, 0UL, 0UL);
}
